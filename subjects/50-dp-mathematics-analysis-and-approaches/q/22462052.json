t;\"><em><strong>[4 marks]</strong></em></p></div>","meta":{"questionId":"22462052","referenceCode":"24M.2.AHL.TZ2.8a","subjectId":"50-dp-mathematics-analysis-and-approaches","title":"Show that arg z=θ; z=2 cos θ.","paper":"2","level":"HL","questionNumber":"a","marksAvailable":"[Maximum mark: 7]","breadcrumbLabels":["Topic 1—Number and algebra","Topic 3— Geometry and trigonometry","Topic 3— Geometry and trigonometry","SL 3.6—Pythagorean identity, double angles","Topic 1—Number and algebra","AHL 1.12—Complex numbers – Cartesian form and Argand diag","Topic 1—Number and algebra","AHL 1.13—Polar and Euler form"],"memberSectionIds":[],"sectionOrders":{}},"schemaVersion":3}